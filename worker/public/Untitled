<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Links</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f7; color: #1d1d1f; }
  header { background: white; padding: 16px 24px; border-bottom: 1px solid #e5e5e5; display: flex; gap: 12px; align-items: center; position: sticky; top: 0; z-index: 10; }
  header h1 { font-size: 20px; font-weight: 700; color: #1d1d1f; margin-right: auto; }
  input[type=text] { border: 1px solid #d2d2d7; border-radius: 10px; padding: 8px 14px; font-size: 14px; outline: none; background: #f5f5f7; }
  input[type=text]:focus { border-color: #0071e3; background: white; }
  #search { width: 220px; }
  .tag-filter { display: flex; gap: 8px; padding: 16px 24px 0; flex-wrap: wrap; }
  .tag-btn { background: white; border: 1px solid #d2d2d7; border-radius: 20px; padding: 4px 14px; font-size: 13px; cursor: pointer; transition: all 0.15s; }
  .tag-btn:hover, .tag-btn.active { background: #0071e3; color: white; border-color: #0071e3; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; padding: 16px 24px 24px; }
  .card { background: white; border-radius: 14px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); transition: transform 0.15s, box-shadow 0.15s; cursor: pointer; position: relative; }
  .card:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.12); }
  .card img { width: 100%; height: 160px; object-fit: cover; background: #e5e5e5; display: block; }
  .card-no-img { width: 100%; height: 160px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; font-size: 40px; }
  .card-body { padding: 14px; }
  .card-title { font-size: 15px; font-weight: 600; line-height: 1.4; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .card-desc { font-size: 13px; color: #6e6e73; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 10px; }
  .card-url { font-size: 12px; color: #0071e3; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; margin-bottom: 10px; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .tag { background: #f0f0f5; border-radius: 6px; padding: 2px 8px; font-size: 11px; color: #6e6e73; }
  .card-date { font-size: 11px; color: #aeaeb2; margin-top: 8px; }
  .delete-btn { position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,0.5); color: white; border: none; border-radius: 50%; width: 26px; height: 26px; cursor: pointer; font-size: 14px; display: none; align-items: center; justify-content: center; }
  .card:hover .delete-btn { display: flex; }
  .empty { text-align: center; padding: 80px 24px; color: #aeaeb2; grid-column: 1/-1; }
  .empty p { font-size: 16px; margin-top: 8px; }
  #tag-input { width: 160px; }
</style>
</head>
<body>

<header>
  <h1>🔖 My Links</h1>
  <input type="text" id="search" placeholder="Search..." oninput="debounceSearch()">
  <input type="text" id="tag-input" placeholder="Filter by tag...">
  <button class="tag-btn" onclick="filterByTag(document.getElementById('tag-input').value)">Go</button>
</header>

<div class="tag-filter" id="tag-cloud"></div>
<div class="grid" id="grid"></div>

<script>
const API = 'http://localhost:8787';
let allTags = new Set();
let searchTimer;

async function loadLinks(search = '', tag = '') {
  const params = new URLSearchParams();
  if (search) params.set('search', search);
  if (tag) params.set('tag', tag);
  const res = await fetch(`${API}/links?${params}`);
  const links = await res.json();
  renderGrid(links);
  updateTagCloud(links);
}

function updateTagCloud(links) {
  allTags = new Set();
  links.forEach(l => {
    if (l.tags) l.tags.split(',').forEach(t => t.trim() && allTags.add(t.trim()));
  });
  const cloud = document.getElementById('tag-cloud');
  cloud.innerHTML = '';
  allTags.forEach(tag => {
    const btn = document.createElement('button');
    btn.className = 'tag-btn';
    btn.textContent = tag;
    btn.onclick = () => filterByTag(tag);
    cloud.appendChild(btn);
  });
}

function filterByTag(tag) {
  document.getElementById('tag-input').value = tag;
  loadLinks('', tag);
}

function debounceSearch() {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    loadLinks(document.getElementById('search').value);
  }, 300);
}

function renderGrid(links) {
  const grid = document.getElementById('grid');
  if (!links.length) {
    grid.innerHTML = '<div class="empty"><div style="font-size:48px">🔖</div><p>No links yet. Share a URL from your iPhone!</p></div>';
    return;
  }
  grid.innerHTML = links.map(l => {
    const tags = l.tags ? l.tags.split(',').filter(t => t.trim()) : [];
    const date = new Date(l.created_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
    const domain = (() => { try { return new URL(l.url).hostname; } catch { return l.url; } })();
    const img = l.thumbnail
      ? `<img src="${l.thumbnail}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" loading="lazy">`
      : '';
    const fallback = `<div class="card-no-img" style="${l.thumbnail ? 'display:none' : ''}">🔗</div>`;
    return `
      <div class="card" onclick="window.open('${l.url}', '_blank')">
        <button class="delete-btn" onclick="event.stopPropagation();deleteLink(${l.id})">✕</button>
        ${img}${fallback}
        <div class="card-body">
          <div class="card-title">${l.title || l.url}</div>
          ${l.description ? `<div class="card-desc">${l.description}</div>` : ''}
          <div class="card-url">${domain}</div>
          ${tags.length ? `<div class="card-tags">${tags.map(t => `<span class="tag">${t.trim()}</span>`).join('')}</div>` : ''}
          <div class="card-date">${date}</div>
        </div>
      </div>`;
  }).join('');
}

async function deleteLink(id) {
  if (!confirm('Delete this link?')) return;
  await fetch(`${API}/links/${id}`, { method: 'DELETE' });
  loadLinks();
}

loadLinks();
</script>
</body>
</html>